{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#C9B28B",
          "background": "#2B1F10",
          "template": " {{ .FormattedMs }} ",
          "properties": {
            "style": "austin",
            "threshold": 500
          }
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "#FF8274",
          "background": "#1C150C",
          "template": " {{ if gt .Code 0 }}✗ {{ .Code }}{{ end }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#F2E3C6",
          "background": "#1C150C",
          "template": " {{ .Path }} ",
          "properties": {
            "style": "full",
            "folder_separator_icon": "/"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#FFD080",
          "background": "#3A2710",
          "template": " {{ .HEAD }}{{ if .Working.Changed }} ●{{ end }}{{ if .Staging.Changed }} ✚{{ end }} ",
          "properties": {
            "branch_icon": "",
            "fetch_status": true
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "type": "time",
          "style": "plain",
          "foreground": "#C9B28B",
          "template": " {{ .CurrentDate | date \"15:04\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#FFB648",
          "template": "❯ "
        }
      ]
    }
  ]
}
