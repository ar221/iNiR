{
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "class": "#98e9c4",
      "comment": "#C9B28Baa",
      "decorator": "#ff734c",
      "enum": "#98e9c4",
      "enumMember": "#ffb446",
      "function": "#73e2bb",
      "interface": "#98e9c4",
      "keyword": "#f579ca",
      "keyword.control": "#f579ca",
      "method": "#73e2bb",
      "namespace": "#98e9c4",
      "number": "#ffb446",
      "operator": "#f579ca",
      "parameter": "#F2E3C6",
      "property": "#85e5bf",
      "regexp": "#ff734c",
      "string": "#c4e14d",
      "struct": "#98e9c4",
      "type": "#98e9c4",
      "typeParameter": "#ffb446",
      "variable": "#F2E3C6",
      "variable.constant": "#ffb446",
      "variable.defaultLibrary": "#ff734c"
    }
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
