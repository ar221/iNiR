{
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "class": "#92BEB4",
      "comment": "#8A9A72aa",
      "decorator": "#D86A3C",
      "enum": "#92BEB4",
      "enumMember": "#C98A2E",
      "function": "#74A39A",
      "interface": "#92BEB4",
      "keyword": "#9E7AA6",
      "keyword.control": "#9E7AA6",
      "method": "#74A39A",
      "namespace": "#92BEB4",
      "number": "#C98A2E",
      "operator": "#9E7AA6",
      "parameter": "#D7B56D",
      "property": "#92BEB4",
      "regexp": "#D86A3C",
      "string": "#6E8E50",
      "struct": "#92BEB4",
